{
  "manifest_version": 3,
  "name": "AI MOM - Meeting Assistant",
  "version": "1.0",
  "description": "Real-time meeting transcription & summary with Groq API",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["ws://localhost:8000/*", "http://localhost:8000/*"],
  "web_accessible_resources": [
    {
      "resources": ["audio-worklet.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "AI MOM"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["slider.css"]
    }
  ]
}
