# ============================================
# AI-MOM Project .gitignore
# Updated: October 2, 2025
# ============================================

# ============================================
# ENVIRONMENT & SECRETS
# ============================================
.env
.env.local
.env.*.local
backend/.env
frontend/.env
browser-extension/.env
test/.env
*.key
*.pem

# Keep example files
!.env.example
!backend/.env.example
!frontend/.env.example

# ============================================
# PYTHON
# ============================================
# Virtual Environments
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/
virtualenv/

# Python Cache
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so
*.egg
*.egg-info/
dist/
build/
.Python

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ============================================
# NODE.JS / FRONTEND
# ============================================
# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
*.local

# Logs
backend/logs/
frontend/logs/
browser-extension/logs/
logs/*.log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Keep log directories with .gitkeep
!logs/.gitkeep
!backend/logs/.gitkeep

# ============================================
# AUDIO FILES (Too large for git)
# ============================================
audio/*.mp3
audio/*.mp4
audio/*.wav
audio/*.m4a
audio/*.flac
audio/*.ogg
audio/*.aac

# Keep README in audio folder
!audio/README.md

# ============================================
# USER DATA & GENERATED CONTENT
# ============================================
# Specific user data files (not examples)
backend/user_profile.json
backend/tests/user_profile.json
test/user_profile.json
tests/user_profile.json
userprofile.json
*.profile
# Generated content directories
backend/meeting_data/
test/meeting_data/
tests/meeting_data/
transcriptions/
summaries/

# Keep meeting_data directories with .gitkeep
!backend/meeting_data/.gitkeep
!test/meeting_data/.gitkeep
!tests/meeting_data/.gitkeep

# Keep example files
!backend/user_profile.json.example
!user_profile.json.example

# ============================================
# IDE & EDITORS
# ============================================
# VSCode
.vscode/
!.vscode/extensions.json

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# OPERATING SYSTEM FILES
# ============================================
# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp
*.bak
.tmp/
temp/
tmp/

# ============================================
# DOCUMENTATION - TEMPORARY ANALYSIS FILES
# (Keep only permanent documentation)
# ============================================
*_ANALYSIS.md
*_ANALYSIS_REPORT.md
*_SUMMARY.md
QUICK_DECISION_GUIDE.md
*_COMPLETE.md
*_FIX.md

# ============================================
# BUILD ARTIFACTS & CACHE
# ============================================
*.pyc
.cache/
.sass-cache/

# ============================================
# TESTING
# ============================================
.pytest_cache/
coverage/
.nyc_output/

# ============================================
# MISC
# ============================================
*.lock
.pnpm-store/
bun.lockb