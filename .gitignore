# AI MOM .gitignore

# Audio files and folders
audio/
*.mp3
*.mp4
*.wav
*.m4a
*.flac
*.ogg

# Test folders and files
tests/
test_*.py
*_test.py
test_*.txt
test_*.json

# Demo UI folder
DemoUI/
demo_ui/

# Documentation folders
docs/
doc/
documentation/

# Report folders
report/
reports/
*.report

# User profile files
userprofile.json
user_profile.json
*.profile

# Virtual environments
venv/
env/
.venv/
.env/
virtualenv/
ENV/
env.bak/
venv.bak/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.tmp/
temp/

# Node modules (if any)
node_modules/

# Build artifacts
build/
dist/
*.egg-info/