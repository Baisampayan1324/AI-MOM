# ============================================
# AI-MOM Project .gitignore
# Updated: October 2, 2025
# ============================================

# ============================================
# ENVIRONMENT & SECRETS
# ============================================
.env
.env.local
.env.*.local
backend/.env
*.key
*.pem

# ============================================
# PYTHON
# ============================================
# Virtual Environments
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/
virtualenv/

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.Python

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ============================================
# NODE.JS / FRONTEND
# ============================================
# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# AUDIO FILES (Too large for git)
# ============================================
audio/*.mp3
audio/*.mp4
audio/*.wav
audio/*.m4a
audio/*.flac
audio/*.ogg
audio/*.aac

# Keep README in audio folder
!audio/README.md

# ============================================
# USER DATA & GENERATED CONTENT
# ============================================
user_profile.json
userprofile.json
*.profile
transcriptions/
summaries/
meeting_data/

# ============================================
# IDE & EDITORS
# ============================================
# VSCode
.vscode/
!.vscode/extensions.json

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# OPERATING SYSTEM FILES
# ============================================
# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp
*.bak
.tmp/
temp/
tmp/

# ============================================
# DOCUMENTATION - TEMPORARY ANALYSIS FILES
# (Keep only permanent documentation)
# ============================================
*_ANALYSIS.md
*_ANALYSIS_REPORT.md
*_SUMMARY.md
QUICK_DECISION_GUIDE.md
*_COMPLETE.md
*_FIX.md

# ============================================
# BUILD ARTIFACTS & CACHE
# ============================================
*.pyc
.cache/
.sass-cache/

# ============================================
# TESTING
# ============================================
.pytest_cache/
coverage/
.nyc_output/

# ============================================
# MISC
# ============================================
*.lock
.pnpm-store/
bun.lockb